# .env.example
# Copy this file to .env and fill in your values.
# Never commit your .env file — it is listed in .gitignore.

# ── Anthropic ──────────────────────────────────────────────────────────────
# Required. Your Anthropic API key, used to call Claude claude-sonnet-4-5 for
# image text extraction and translation.
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── LangSmith ──────────────────────────────────────────────────────────────
# Required for tracing. Your LangSmith API key.
# Sign up for free at: https://smith.langchain.com
# Then go to Settings → API Keys → Create API Key.
LANGCHAIN_API_KEY=

# Enable or disable LangSmith trace upload.
# Set to "true" to send traces; "false" to run without tracing.
# Default: true
LANGCHAIN_TRACING_V2=true

# The project name shown in your LangSmith dashboard.
# All pipeline traces will be grouped under this project.
# Default: image-translation-pipeline
LANGCHAIN_PROJECT=image-translation-pipeline

# ── Pipeline settings ──────────────────────────────────────────────────────
# Maximum allowed image upload size in megabytes.
# Requests exceeding this limit are rejected with HTTP 413.
# Default: 10
MAX_IMAGE_SIZE_MB=10

# Default translation target language when the caller does not specify one.
# Any human-readable language name accepted by Claude works here.
# Default: English
DEFAULT_TARGET_LANGUAGE=English

# ── Model settings (optional overrides) ───────────────────────────────────
# Claude model used for extraction and translation.
# Change only if you have access to a different model version.
# Default: claude-sonnet-4-5
EXTRACTION_CLAUDE_MODEL=claude-sonnet-4-5

# Maximum tokens the extraction model may produce per request.
# Increase for images with many small text regions.
# Default: 4096
EXTRACTION_MAX_TOKENS=4096
