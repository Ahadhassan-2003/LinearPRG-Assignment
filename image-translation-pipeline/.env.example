# .env.example — copy this file to .env and fill in your values

# Anthropic API key — used to call Claude models for text extraction and translation
ANTHROPIC_API_KEY=

# LangSmith API key — used for pipeline tracing and observability
LANGCHAIN_API_KEY=

# Enable LangSmith tracing (set to "true" or "false")
LANGCHAIN_TRACING_V2=true

# LangSmith project name shown in the LangSmith dashboard
LANGCHAIN_PROJECT=image-translation-pipeline

# Maximum image upload size in megabytes
MAX_IMAGE_SIZE_MB=10

# Default target language for translation
DEFAULT_TARGET_LANGUAGE=English
